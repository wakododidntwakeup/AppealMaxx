@model AppealMaxxWeb.Models.Meal

@{
    ViewData["Title"] = "Edit Meal";
}

<section class="tracker-form-page">

    <div class="tracker-form-shell">

        <div class="tracker-form-info meal-info">
            <span class="form-badge">Nutrition</span>

            <h1>Edit Meal</h1>

            <p>
                Update your meal record and keep your nutrition history accurate.
            </p>

            <div class="info-list">
                <div>
                    <strong>ID</strong>
                    <span>@Model.MealId</span>
                </div>

                <div>
                    <strong>Type</strong>
                    <span>Meal record</span>
                </div>

                <div>
                    <strong>Status</strong>
                    <span>Editable</span>
                </div>
            </div>
        </div>

        <div class="tracker-form-card">
            <h2>Edit Nutrition</h2>
            <p>Change saved meal information.</p>

            <form asp-action="Edit" class="clean-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="MealId" />

                <div class="input-group-custom">
                    <label asp-for="UserId">User ID</label>
                    <input asp-for="UserId" />
                    <span asp-validation-for="UserId" class="text-danger"></span>
                </div>

                <div class="input-group-custom">
                    <label asp-for="MealName">Meal Name</label>
                    <input asp-for="MealName" />
                    <span asp-validation-for="MealName" class="text-danger"></span>
                </div>

                <div class="input-row">
                    <div class="input-group-custom">
                        <label asp-for="Calories">Calories</label>
                        <input asp-for="Calories" />
                        <span asp-validation-for="Calories" class="text-danger"></span>
                    </div>

                    <div class="input-group-custom">
                        <label asp-for="MealDate">Meal Date</label>
                        <input asp-for="MealDate" type="datetime-local" />
                        <span asp-validation-for="MealDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="main-button">Save Changes</button>
                    <a asp-action="Index" class="ghost-button">Back to Meals</a>
                </div>
            </form>
        </div>

    </div>

</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}