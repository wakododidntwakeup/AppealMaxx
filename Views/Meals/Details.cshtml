@model AppealMaxxWeb.Models.User

@{
    ViewData["Title"] = "Personal Profile";
}

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <h2>Personal Profile</h2>
            <p class="mb-0">User information in AppealMaxx system</p>
        </div>

        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Full Name</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.FullName)</dd>

                <dt class="col-sm-3">Age</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Age)</dd>

                <dt class="col-sm-3">Weight</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Weight)</dd>

                <dt class="col-sm-3">Height</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Height)</dd>
            </dl>

            <a asp-action="Edit" asp-route-id="@Model?.UserId" class="btn btn-warning">Edit Profile</a>
            <a asp-controller="Meals" asp-action="Create" class="btn btn-success">Add Meal</a>
            <a asp-controller="Workouts" asp-action="Create" class="btn btn-info">Add Workout</a>
            <a asp-action="Index" class="btn btn-secondary">Back to Users</a>
        </div>
    </div>
</div>