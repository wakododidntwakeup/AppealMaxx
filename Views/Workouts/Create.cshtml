@model AppealMaxxWeb.Models.Workout

@{
    ViewData["Title"] = "Add Workout";
}

<section class="tracker-form-page">

    <div class="tracker-form-shell">

        <div class="tracker-form-info workout-info">
            <span class="form-badge">Training</span>

            <h1>Add Workout</h1>

            <p>
                Save your training session, duration and burned calories.
                Build discipline through clean activity tracking.
            </p>

            <div class="info-list">
                <div>
                    <strong>01</strong>
                    <span>Choose user ID</span>
                </div>

                <div>
                    <strong>02</strong>
                    <span>Add workout name</span>
                </div>

                <div>
                    <strong>03</strong>
                    <span>Track burned energy</span>
                </div>
            </div>
        </div>

        <div class="tracker-form-card">
            <h2>Workout Record</h2>
            <p>Create a new training entry.</p>

            <form asp-action="Create" class="clean-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="input-group-custom">
                    <label asp-for="UserId">User ID</label>
                    <input asp-for="UserId" placeholder="Example: 1" />
                    <span asp-validation-for="UserId" class="text-danger"></span>
                </div>

                <div class="input-group-custom">
                    <label asp-for="WorkoutName">Workout Name</label>
                    <input asp-for="WorkoutName" placeholder="Running, gym, cardio..." />
                    <span asp-validation-for="WorkoutName" class="text-danger"></span>
                </div>

                <div class="input-row">
                    <div class="input-group-custom">
                        <label asp-for="DurationMinutes">Duration</label>
                        <input asp-for="DurationMinutes" placeholder="60" />
                        <span asp-validation-for="DurationMinutes" class="text-danger"></span>
                    </div>

                    <div class="input-group-custom">
                        <label asp-for="BurnedCalories">Burned Calories</label>
                        <input asp-for="BurnedCalories" placeholder="800" />
                        <span asp-validation-for="BurnedCalories" class="text-danger"></span>
                    </div>
                </div>

                <div class="input-group-custom">
                    <label asp-for="WorkoutDate">Workout Date</label>
                    <input asp-for="WorkoutDate" type="datetime-local" />
                    <span asp-validation-for="WorkoutDate" class="text-danger"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="main-button">Save Workout</button>
                    <a asp-action="Index" class="ghost-button">Back to Workouts</a>
                </div>
            </form>
        </div>

    </div>

</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}