@model AppealMaxxWeb.Models.User

@{
    ViewData["Title"] = "Registration";
}

<section class="register-page">
    <div class="register-card">

        <div class="register-info">
            <div class="mini-logo">AppealMaxx</div>

            <h1>Start your fitness journey</h1>

            <p>
                Create your personal fitness profile and enter your private dashboard
                with meals, workouts and body progress tracking.
            </p>

            <div class="features">
                <div>Workout tracking</div>
                <div>Meal control</div>
                <div>Personal progress</div>
            </div>
        </div>

        <div class="register-form">
            <h2>Registration</h2>
            <p>Create your personal cabinet</p>

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="input-group-custom">
                    <label asp-for="FullName">Full Name</label>
                    <input asp-for="FullName" placeholder="Enter your full name" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="input-row">
                    <div class="input-group-custom">
                        <label asp-for="Age">Age</label>
                        <input asp-for="Age" placeholder="17" />
                        <span asp-validation-for="Age" class="text-danger"></span>
                    </div>

                    <div class="input-group-custom">
                        <label asp-for="Weight">Weight</label>
                        <input asp-for="Weight" placeholder="68" />
                        <span asp-validation-for="Weight" class="text-danger"></span>
                    </div>
                </div>

                <div class="input-group-custom">
                    <label asp-for="Height">Height</label>
                    <input asp-for="Height" placeholder="180" />
                    <span asp-validation-for="Height" class="text-danger"></span>
                </div>

                <button type="submit" class="main-button">
                    Create Profile
                </button>
            </form>
        </div>

    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}