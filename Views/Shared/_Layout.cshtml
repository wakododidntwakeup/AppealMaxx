@using Microsoft.AspNetCore.Http

@{
    var isLoggedIn = Context.Session.GetInt32("CurrentUserId") != null;
    var userName = Context.Session.GetString("CurrentUserName");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AppealMaxx</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <div class="page-bg"></div>

    <header class="site-header">
        <nav class="top-navbar">
            <a class="logo" asp-controller="Users" asp-action="Create">
                <span>Appeal</span>Maxx
            </a>

            @if (isLoggedIn)
            {
                <div class="nav-links">
                    <button onclick="history.back()" class="nav-back-button">← Back</button>

                    <a asp-controller="Users" asp-action="Index">Users</a>
                    <a asp-controller="Meals" asp-action="Index">Meals</a>
                    <a asp-controller="Workouts" asp-action="Index">Workouts</a>

                    <span class="nav-user">@userName</span>

                    <a asp-controller="Users" asp-action="Logout" class="logout-nav">Logout</a>
                </div>
            }
        </nav>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="main-footer">
        <div class="footer-left">
            <h2><span>Appeal</span>Maxx</h2>
            <p>
                Premium fitness tracking system for users, meals, workouts and progress control.
            </p>
        </div>

        <div class="footer-center">
            <div>
                <strong>ASP.NET MVC</strong>
                <span>Architecture</span>
            </div>

            <div>
                <strong>SQL Server</strong>
                <span>Database</span>
            </div>

            <div>
                <strong>Session Auth</strong>
                <span>User Cabinet</span>
            </div>
        </div>

        <div class="footer-right">
            <p>© 2026 AppealMaxx</p>
            <span>Final database project</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>